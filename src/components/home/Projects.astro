---
import Icon from '../Icon.astro';
import { projects } from '../../data/projects';
---

<div class="flex flex-col gap-10">
  <div class="flex flex-col">
    <span class="font-bold text-[20px]">Personal Projects</span>
    <span class="text-[18px] text-neutral-600 dark:text-neutral-400">
      Tinkering through code in various domains
    </span>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {projects.map((project) => (
      <a
        href={`/portfolio?tab=personal#${project.id}`}
        class="cursor-pointer bg-neutral-50 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 hover:bg-neutral-100 dark:hover:bg-neutral-800 relative group rounded-lg overflow-hidden min-h-[210px] transition-colors"
      >
        <div class="p-4 flex flex-col justify-between h-full pb-10">
          <div class="flex items-start justify-between">
            {project.image ? (
              <img
                src={project.image}
                alt={project.title}
                class="rounded-md w-12 h-12 object-cover"
              />
            ) : (
              <div class="w-12 h-12 rounded-md bg-neutral-200 dark:bg-neutral-800 flex items-center justify-center">
                <Icon name="layers" size={20} class="text-neutral-500" />
              </div>
            )}
            
            {project.externalLink && (
              <div
                class="text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-transform hover:scale-110"
                onclick={`event.preventDefault(); window.open('${project.externalLink}', '_blank');`}
              >
                <Icon name="external-link" size={20} />
              </div>
            )}
          </div>
          
          <div class="mt-4">
            <h3 class="text-[15px] font-semibold text-neutral-900 dark:text-white flex items-center gap-2">
              {project.title}
              {project.active && (
                <span class="w-2 h-2 rounded-full bg-green-500" title="Active"></span>
              )}
            </h3>
            <p class="text-[14px] text-neutral-600 dark:text-neutral-400 mt-1">
              {project.description}
            </p>
            
            {project.tags && project.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mt-3">
                {project.tags.map((tag) => (
                  <span class="px-2 py-0.5 rounded-md bg-neutral-200 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 text-xs">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </div>
      </a>
    ))}
  </div>
</div>
