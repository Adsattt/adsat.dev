---
import Icon from './Icon.astro';
---

<footer class="py-4 pt-6 mt-16 pb-16 lg:pb-5 dark:bg-gray-1000 rounded-sm border-t border-neutral-200 dark:border-neutral-800">
  <div class="flex justify-center items-center gap-4">
    <a
      href="https://x.com/adsat_"
      target="_blank"
      rel="noopener noreferrer"
      class="text-neutral-600 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-50 transition-colors"
    >
      <Icon name="twitter" size={20} />
    </a>
    <a
      href="https://github.com/Adsattt"
      target="_blank"
      rel="noopener noreferrer"
      class="text-neutral-600 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-50 transition-colors"
    >
      <Icon name="github" size={20} />
    </a>
    <a
      href="https://www.linkedin.com/in/adsat"
      target="_blank"
      rel="noopener noreferrer"
      class="text-neutral-600 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-50 transition-colors"
    >
      <Icon name="linkedin" size={20} />
    </a>
    <a
      href="https://www.instagram.com/adsattt"
      target="_blank"
      rel="noopener noreferrer"
      class="text-neutral-600 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-50 transition-colors"
    >
      <Icon name="instagram" size={20} />
    </a>
  </div>
  <div class="text-center text-neutral-600 dark:text-neutral-400 my-4 text-sm">
    End of line.
  </div>
</footer>
