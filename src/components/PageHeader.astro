---
interface Props {
  title?: string;
  showBackButton?: boolean;
  backHref?: string;
}

const { title, showBackButton = false, backHref = '/' } = Astro.props;
---

{!showBackButton && (
  <div class="block lg:hidden sticky top-0 z-30 flex items-center justify-between px-5 py-3.5 bg-white/70 dark:bg-neutral-900/70 backdrop-blur-sm border-b border-neutral-200 dark:border-neutral-800">
    <div class="flex items-center gap-3">
      <button
        id="sidebar-open"
        class="flex items-center justify-center w-7 h-7 rounded-md hover:bg-neutral-100 dark:hover:bg-neutral-800 cursor-pointer"
        aria-label="Open menu"
      >
        <div class="w-7 h-7 rounded-md bg-neutral-900 dark:bg-white flex items-center justify-center text-white dark:text-neutral-900 text-xs font-bold">
          A
        </div>
      </button>
      {title && (
        <h2 class="text-sm font-bold text-neutral-900 dark:text-white line-clamp-1">
          {title}
        </h2>
      )}
    </div>
  </div>
)}

{showBackButton && (
  <div class="sticky top-0 z-30 flex items-center gap-3 px-5 py-3.5 bg-white/70 dark:bg-neutral-900/70 backdrop-blur-sm border-b border-neutral-200 dark:border-neutral-800">
    <a
      href={backHref}
      class="flex items-center justify-center w-6 h-6 rounded-lg hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6"/>
      </svg>
    </a>
    {title && (
      <h2 class="text-sm font-bold text-neutral-900 dark:text-white line-clamp-1">
        {title}
      </h2>
    )}
  </div>
)}
