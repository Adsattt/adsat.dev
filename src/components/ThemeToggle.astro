---
// No unused variable — currentPath was leftover
---

<button
  id="theme-toggle"
  class="w-full p-2 rounded-md hover:bg-neutral-100 dark:hover:bg-neutral-700 text-neutral-700 dark:text-neutral-300 flex items-center justify-center transition-opacity opacity-60 hover:opacity-100 cursor-pointer"
  aria-label="Toggle theme"
  title="Toggles light & dark"
>
  <!-- Moon: shown when in light mode (click to go dark) -->
  <svg id="icon-moon" class="w-4 h-4 hidden" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
  </svg>
  <!-- Sun: shown when in dark mode (click to go light) -->
  <svg id="icon-sun" class="w-4 h-4 hidden" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="4"/>
    <path d="M12 2v2M12 20v2m-7.07-14.93 1.41 1.41M18.66 18.66l1.41 1.41M2 12h2M20 12h2m-3.34-7.07-1.41 1.41M7.76 18.24l-1.41 1.41"/>
  </svg>
</button>

<!-- Inline: runs before paint to avoid FOUC -->
<script is:inline>
  function syncThemeIcons() {
    const isDark = document.documentElement.classList.contains('dark')
    const moon = document.getElementById('icon-moon')
    const sun = document.getElementById('icon-sun')
    if (moon) moon.classList.toggle('hidden', isDark)
    if (sun) sun.classList.toggle('hidden', !isDark)
  }
  syncThemeIcons()
  document.addEventListener('astro:page-load', syncThemeIcons)
</script>

<!-- Bundled: handles click + circle-expand view transition -->
<script>
  // Detect fill mode for the Web Animations API clip-path animation.
  // Chromium supports 'both'; others need 'none' to avoid visual artifacts.
  const chooseFill = (): FillMode => {
    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    const uach = (navigator as any).userAgentData
    if (uach?.brands?.length) {
      const isChromium = uach.brands.some((b: { brand: string }) =>
        /Chrom(e|ium)/i.test(b.brand)
      )
      return isChromium ? 'both' : 'none'
    }
    return 'none'
  }
  const fill = chooseFill()

  function setupThemeToggle() {
    const btn = document.getElementById('theme-toggle')
    if (!btn) return

    const toggle = () => {
      document.documentElement.classList.toggle('dark')
      const isDark = document.documentElement.classList.contains('dark')
      localStorage.setItem('theme', isDark ? 'dark' : 'light')

      // sync icons
      const moon = document.getElementById('icon-moon')
      const sun = document.getElementById('icon-sun')
      if (moon) moon.classList.toggle('hidden', isDark)
      if (sun) sun.classList.toggle('hidden', !isDark)
    }

    const handleClick = (event: MouseEvent) => {
      const supportsTransition =
        typeof document.startViewTransition === 'function' &&
        !window.matchMedia('(prefers-reduced-motion: reduce)').matches

      if (!supportsTransition) {
        toggle()
        return
      }

      const x = event.clientX
      const y = event.clientY
      const endRadius = Math.hypot(
        Math.max(x, innerWidth - x),
        Math.max(y, innerHeight - y)
      )

      const transition = document.startViewTransition(() => toggle())

      transition.ready.then(() => {
        const isDark = document.documentElement.classList.contains('dark')
        const clipPath = [
          `circle(0px at ${x}px ${y}px)`,
          `circle(${endRadius}px at ${x}px ${y}px)`,
        ]

        document.documentElement.animate(
          { clipPath: isDark ? clipPath.reverse() : clipPath },
          {
            duration: 400,
            easing: 'ease-out',
            fill,
            pseudoElement: isDark
              ? '::view-transition-old(root)'
              : '::view-transition-new(root)',
          }
        )
      })
    }

    btn.removeEventListener('click', handleClick as EventListener)
    btn.addEventListener('click', handleClick as EventListener)
  }

  setupThemeToggle()
  document.addEventListener('astro:page-load', setupThemeToggle)
</script>
