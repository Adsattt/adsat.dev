---
import Icon from './Icon.astro';
import ThemeToggle from './ThemeToggle.astro';
import { routes } from '../data/navigation';

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<!-- Mobile overlay -->
<div
  id="sidebar-overlay"
  class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden"
></div>

<!-- Sidebar -->
<nav
  id="sidebar"
  class="fixed top-0 left-0 h-full z-50 flex flex-col max-h-screen min-h-screen
    w-72 lg:w-56 2xl:w-72
    -translate-x-full lg:translate-x-0
    border-r border-neutral-200 dark:border-neutral-800
    bg-white lg:bg-neutral-50 dark:bg-neutral-900
    transition-transform duration-200 ease-in-out
    overflow-y-auto pb-10 lg:pb-0"
>
  <!-- Logo -->
  <div class="sticky top-0 z-10 flex flex-col justify-center px-5 py-3.5 bg-inherit">
    <a href="/" class="flex items-center gap-3 cursor-pointer">
      <div class="w-7 h-7 rounded-md bg-neutral-900 dark:bg-white flex items-center justify-center text-white dark:text-neutral-900 text-xs font-bold">
        A
      </div>
      <h2 class="text-sm font-bold text-neutral-900 dark:text-white line-clamp-1">
        adsat
      </h2>
    </a>
  </div>

  <!-- Navigation -->
  <div class="flex-1 px-3 lg:py-3 space-y-1">
    <!-- Main nav (hidden on lg since it's in sidebar, show on mobile overlay) -->
    <ul class="space-y-1">
      {routes[0].items.map((item) => (
        <li class="flex items-stretch">
          <a
            href={item.href}
            class:list={[
              'flex flex-1 items-center space-x-3 rounded-md px-2 py-1.5 text-sm font-medium transition-colors',
              isActive(item.href)
                ? 'bg-neutral-900 text-white dark:bg-neutral-100 dark:text-neutral-900'
                : 'text-neutral-700 hover:bg-neutral-100 hover:text-neutral-900 dark:text-neutral-300 dark:hover:bg-neutral-700 dark:hover:text-white',
            ]}
          >
            <span class="flex items-center justify-center w-4">
              <Icon name={item.icon} size={16} />
            </span>
            <span class="flex-1">{item.label}</span>
          </a>
        </li>
      ))}
    </ul>

    <!-- Other nav groups -->
    {routes.slice(1).map((group) => (
      <ul class="space-y-1">
        {group.label && (
          <h4 class="px-2 pt-5 pb-2 text-xs font-semibold text-neutral-500 dark:text-neutral-400/60">
            {group.label}
          </h4>
        )}
        {group.items.map((item) => (
          <li class="flex items-stretch">
            <a
              href={item.href}
              target={item.isExternal ? '_blank' : undefined}
              rel={item.isExternal ? 'noopener noreferrer' : undefined}
              class:list={[
                'flex flex-1 items-center space-x-3 rounded-md px-2 py-1.5 text-sm font-medium transition-colors',
                isActive(item.href)
                  ? 'bg-neutral-900 text-white dark:bg-neutral-100 dark:text-neutral-900'
                  : 'text-neutral-700 hover:bg-neutral-100 hover:text-neutral-900 dark:text-neutral-300 dark:hover:bg-neutral-700 dark:hover:text-white',
              ]}
            >
              <span class="flex items-center justify-center w-4">
                <Icon name={item.icon} size={16} />
              </span>
              <span class="flex-1">{item.label}</span>
              {item.isExternal && (
                <span class="flex items-center justify-center w-4 text-neutral-500 dark:text-neutral-400">
                  <Icon name="external-link" size={12} />
                </span>
              )}
            </a>
          </li>
        ))}
      </ul>
    ))}
  </div>

  <!-- Theme toggle -->
  <div class="mt-auto px-3 py-4 border-t border-neutral-200 dark:border-neutral-800">
    <ThemeToggle />
  </div>
</nav>

<script is:inline>
  function setupSidebar() {
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    const openBtn = document.getElementById('sidebar-open');

    function openSidebar() {
      sidebar?.classList.remove('-translate-x-full');
      sidebar?.classList.add('translate-x-0', 'shadow-lg');
      overlay?.classList.remove('hidden');
    }

    function closeSidebar() {
      sidebar?.classList.add('-translate-x-full');
      sidebar?.classList.remove('translate-x-0', 'shadow-lg');
      overlay?.classList.add('hidden');
    }

    // Remove old listeners to avoid duplicates
    openBtn?.removeEventListener('click', openSidebar);
    overlay?.removeEventListener('click', closeSidebar);

    openBtn?.addEventListener('click', openSidebar);
    overlay?.addEventListener('click', closeSidebar);

    // Close on nav link click (mobile)
    sidebar?.querySelectorAll('a').forEach((link) => {
      // Remove first to be safe
      link.removeEventListener('click', closeSidebar);
      link.addEventListener('click', () => {
        if (window.innerWidth < 1024) closeSidebar();
      });
    });

    // Expose for external use
    window.__closeSidebar = closeSidebar;
    window.__openSidebar = openSidebar;
  }

  setupSidebar();
  document.addEventListener('astro:page-load', setupSidebar);
</script>
