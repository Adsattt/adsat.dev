---
import type { MarkdownHeading } from 'astro'

interface Props {
  headings: MarkdownHeading[]
}

const { headings } = Astro.props

// Filter to h2 and h3 only
const filteredHeadings = headings.filter(h => h.depth >= 2 && h.depth <= 3)
---

{filteredHeadings.length > 0 && (
  <aside class="hidden xl:block w-56 shrink-0">
    <nav
      id="toc-nav"
      class="sticky top-8 max-h-[calc(100vh-4rem)] overflow-y-auto pr-2 text-sm"
    >
      <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-neutral-500 dark:text-neutral-400">
        On this page
      </p>
      <table-of-contents>
        <ul class="space-y-1.5">
          {filteredHeadings.map((h) => (
            <li
              style={h.depth === 3 ? 'padding-left: 0.875rem' : ''}
            >
              <a
                href={`#${h.slug}`}
                class="toc-link block py-0.5 text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors leading-snug"
                data-heading-id={h.slug}
              >
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </table-of-contents>
    </nav>
  </aside>
)}

<style>
  .toc-link[aria-current="true"] {
    color: rgb(17 24 39); /* neutral-900 */
    font-weight: 500;
  }
  :global(.dark) .toc-link[aria-current="true"] {
    color: rgb(243 244 246); /* neutral-100 */
    font-weight: 500;
  }
</style>

<script>
  class TableOfContents extends HTMLElement {
    #observer: IntersectionObserver | null = null;
    #headingMap = new Map<Element, HTMLAnchorElement>();
    #activeHeading: Element | null = null;
    #activeLink: HTMLAnchorElement | null = null;

    connectedCallback() {
      // Use requestIdleCallback for better performance
      const onIdle = window.requestIdleCallback || ((cb) => setTimeout(cb, 1));
      onIdle(() => this.#init());
    }

    disconnectedCallback() {
      this.#observer?.disconnect();
      this.#observer = null;
      this.#headingMap.clear();
    }

    #init() {
      const links = Array.from(
        this.querySelectorAll<HTMLAnchorElement>('.toc-link')
      );
      if (!links.length) return;

      // Build map: heading el -> toc anchor
      for (const link of links) {
        const id = link.getAttribute('data-heading-id');
        if (!id) continue;
        const heading = document.getElementById(id);
        if (heading) this.#headingMap.set(heading, link);
      }

      this.#observer = new IntersectionObserver(
        (entries) => {
          if (!entries.length) return;

          // Get the latest triggered heading and determine which one should be active
          let latest = entries[0];
          for (let i = 1; i < entries.length; i++) {
            if (entries[i].time > latest.time) latest = entries[i];
          }
          
          if (!latest.target) return;

          // If heading is below 1/4 of viewport, highlight previous heading instead to prevent premature active state
          const isLocatedBelow = latest.boundingClientRect.top > window.innerHeight / 4;
          const targetHeading = isLocatedBelow 
            ? this.#getPreviousHeading(latest.target) 
            : latest.target;

          if (!targetHeading || targetHeading === this.#activeHeading) return;

          const link = this.#headingMap.get(targetHeading);
          if (!link) return;

          // Remove aria-current from previous
          if (this.#activeLink) {
            this.#activeLink.removeAttribute('aria-current');
          }
          link.setAttribute('aria-current', 'true');
          
          // Auto-scroll TOC to keep active link visible
          link.scrollIntoView({ behavior: 'smooth', block: 'center' });

          this.#activeHeading = targetHeading;
          this.#activeLink = link;
        },
        {
          rootMargin: '0% 0% -75% 0%',
          threshold: 0,
        }
      );

      for (const heading of this.#headingMap.keys()) {
        this.#observer.observe(heading);
      }
    }

    #getPreviousHeading(currentHeading: Element) {
      let prev = null;
      for (const h of this.#headingMap.keys()) {
        if (h === currentHeading) return prev;
        prev = h;
      }
      return null;
    }
  }

  if (!customElements.get('table-of-contents')) {
    customElements.define('table-of-contents', TableOfContents);
  }
</script>
